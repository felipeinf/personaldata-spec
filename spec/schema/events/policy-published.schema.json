{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personaldata.dev/schemas/v0/events/policy-published.schema.json",
  "allOf": [
    { "$ref": "./event-base.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "policy_published" },
        "payload": { "$ref": "#/$defs/PolicyPublishedPayload" }
      },
      "required": ["payload"]
    }
  ],
  "$defs": {
    "PolicyPublishedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyVersionId", "purposes"],
      "properties": {
        "policyVersionId": {
          "$ref": "../shared/primitives.schema.json#/$defs/Uuid"
        },
        "purposes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "../shared/primitives.schema.json#/$defs/PurposeReference"
          }
        }
      }
    }
  }
}
