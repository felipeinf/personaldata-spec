{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personaldata.dev/schemas/v0/shared/enums.schema.json",
  "$defs": {
    "EventType": {
      "type": "string",
      "enum": [
        "policy_published",
        "information_presented",
        "consent_granted",
        "consent_revoked",
        "consent_superseded"
      ]
    },
    "LegalBasis": {
      "type": "string",
      "enum": ["consent"]
    },
    "PurposeStatus": {
      "type": "string",
      "enum": ["active", "deprecated"]
    },
    "Mechanism": {
      "type": "string",
      "enum": [
        "web_checkbox",
        "web_button",
        "written_signature",
        "electronic_signature",
        "verbal_recorded",
        "api_explicit"
      ]
    },
    "RetentionKind": {
      "type": "string",
      "enum": ["fixed", "conditional"]
    }
  }
}
